### List latest published stock summaries
GET {{baseUrl}}/v1/stocks
Accept: application/json

### List latest published stock summaries in zh-TW
GET {{baseUrl}}/v1/stocks?locale=zh-TW
Accept: application/json

### Get the latest published stock detail
GET {{baseUrl}}/v1/stocks/{{ticker}}
Accept: application/json

### Get the latest published stock detail in zh-TW
GET {{baseUrl}}/v1/stocks/{{ticker}}?locale=zh-TW
Accept: application/json

### List historical report summaries
GET {{baseUrl}}/v1/stocks/{{ticker}}/reports
Accept: application/json

### List historical report summaries in zh-TW
GET {{baseUrl}}/v1/stocks/{{ticker}}/reports?locale=zh-TW
Accept: application/json

### Get one historical report detail by reportId
GET {{baseUrl}}/v1/stocks/{{ticker}}/reports/{{reportId}}
Accept: application/json

### Get one historical report detail by reportId in zh-TW
GET {{baseUrl}}/v1/stocks/{{ticker}}/reports/{{reportId}}?locale=zh-TW
Accept: application/json
